<Window x:Class="Snake.leaderboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Snake"
        mc:Ignorable="d"
        Title="leaderboard" Height="450" Width="430">
    <Canvas>
        <!-- KI: Chatgpt -->
        <!-- Prompt: wenn ich ein rect habe in wpf c# kann ich irgendwie einen gradient machen damit es in der mitte heller ist und je weiter nach außen desto dünkler wird es -->
        <!-- KI-Anfang -->
        <Rectangle Width="420" Height="485">
            <Rectangle.Fill>
                <RadialGradientBrush>
                    <!-- Mitte (hell) -->
                    <GradientStop Color="#4D4864" Offset="0.0"/>

                    <!-- Rand (dunkler) -->
                    <GradientStop Color="#1C1923" Offset="1.0"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Label Content="Die Top 10 Snakes" Canvas.Left="86" Canvas.Top="43" FontSize="30" Foreground="#7AFE80"/>
        <ListBox x:Name="lb_scores" Height="210" Width="204" d:ItemsSource="{d:SampleData ItemCount=10}" Canvas.Left="108" Canvas.Top="138" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <!-- KI-Ende -->
    </Canvas>
</Window>
