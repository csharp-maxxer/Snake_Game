<Window x:Class="Snake.game_window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Snake"
        mc:Ignorable="d"
        Title="game_window" Height="508" Width="435" Loaded="Window_Loaded" KeyDown="Window_KeyDown">
    <Canvas>
        <Rectangle Height="470" Width="420" Fill="#1C1923" />
        <Rectangle Height="50" Canvas.Left="0" Stroke="Transparent" Canvas.Top="0" Width="420" Fill="#1C1923"/>
        <Canvas Height="400" Canvas.Left="10" Canvas.Top="60" Width="400" HorizontalAlignment="Center" VerticalAlignment="Top" Background="Transparent" Name="Canvas_grid"/>
        <Label Name="Lbl_Score" Content="Score: 0" Canvas.Left="0" Canvas.Top="0" Height="50" Width="420" Foreground="White" FontSize="30" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>


    </Canvas>
</Window>
