<Window x:Class="Snake.settings_window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Snake"
        mc:Ignorable="d"
        Title="settings_window" Height="485" Width="430" ResizeMode="NoResize">
    <Canvas>
        <!-- KI: Chatgpt -->
        <!-- Prompt: wenn ich ein rect habe in wpf c# kann ich irgendwie einen gradient machen damit es in der mitte heller ist und je weiter nach außen desto dünkler wird es -->
        <!-- KI-Anfang -->
        <Rectangle Width="420" Height="485">
            <Rectangle.Fill>
                <RadialGradientBrush>
                    <!-- Mitte (hell) -->
                    <GradientStop Color="#4D4864" Offset="0.0"/>

                    <!-- Rand (dunkler) -->
                    <GradientStop Color="#1C1923" Offset="1.0"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <!-- KI-Ende -->

        <Rectangle Height="14" Canvas.Left="23"  Canvas.Top="24" Width="45" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
