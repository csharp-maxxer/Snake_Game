        <Rectangle Height="28" Canvas.Left="53"  Canvas.Top="54" Width="15" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="14" Canvas.Left="23"  Canvas.Top="48" Width="45" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="14" Canvas.Left="23"  Canvas.Top="73" Width="45" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="13" Canvas.Left="76"  Canvas.Top="74" Width="39" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="28" Canvas.Left="76"  Canvas.Top="27" Width="15" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="28" Canvas.Left="76"  Canvas.Top="54" Width="15" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="12" Canvas.Left="77"  Canvas.Top="50" Width="32" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="13" Canvas.Left="76"  Canvas.Top="24" Width="39" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="62" Canvas.Left="134"  Canvas.Top="24" Width="16" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="14" Canvas.Left="120"  Canvas.Top="24" Width="45" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="62" Canvas.Left="185"  Canvas.Top="24" Width="16" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="14" Canvas.Left="171"  Canvas.Top="24" Width="45" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="62" Canvas.Left="221"  Canvas.Top="24" Width="16" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="62" Canvas.Left="245"  Canvas.Top="24" Width="16" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="62" Canvas.Left="274"  Canvas.Top="24" Width="16" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="26" Canvas.Left="251"  Canvas.Top="36" Width="16" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="26" Canvas.Left="267"  Canvas.Top="43" Width="16" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="62" Canvas.Left="295"  Canvas.Top="24" Width="16" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="34" Canvas.Left="330"  Canvas.Top="52" Width="16" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="15" Canvas.Left="302"  Canvas.Top="71" Width="44" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="15" Canvas.Left="302"  Canvas.Top="24" Width="44" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="12" Canvas.Left="320"  Canvas.Top="50" Width="26" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="14" Canvas.Left="352"  Canvas.Top="24" Width="45" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="28" Canvas.Left="352"  Canvas.Top="27" Width="15" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="28" Canvas.Left="382"  Canvas.Top="54" Width="15" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="14" Canvas.Left="352"  Canvas.Top="48" Width="45" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Rectangle Height="14" Canvas.Left="352"  Canvas.Top="73" Width="45" Fill="#7AFE80" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Label Name="Lbl_Feldweite" Foreground="#7AFE80" FontWeight="Bold" FontSize="20" Content="0" Canvas.Left="30" Canvas.Top="148" Width="47" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Label Name="Lbl_Feldhöhe" Foreground="#7AFE80" FontWeight="Bold" FontSize="20" Content="0" Canvas.Left="30" Canvas.Top="218" Width="47" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Label Name="Lbl_Startlenght" Foreground="#7AFE80" FontWeight="Bold" FontSize="20" Content="0" Canvas.Left="30" Canvas.Top="288" Width="47" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Label Name="Lbl_Startspeed" VerticalContentAlignment="Center" Foreground="#7AFE80" FontWeight="Bold" FontSize="20" Content="0" Canvas.Left="30" Canvas.Top="358" Width="47" HorizontalAlignment="Center" VerticalAlignment="Top"/>

        <Slider x:Name="Slider_Feldweite" Canvas.Left="77" Canvas.Top="160" Width="154" HorizontalAlignment="Center" VerticalAlignment="Top" Minimum="5" Maximum="20" Value="5" ValueChanged="Slider_Feldweite_ValueChanged" IsSnapToTickEnabled="True" TickFrequency="1"/>
        <Slider x:Name="Slider_Feldhöhe" Canvas.Left="77" Canvas.Top="230" Width="154" HorizontalAlignment="Center" VerticalAlignment="Top" Minimum="5" Maximum="20" Value="5" ValueChanged="Slider_Feldhöhe_ValueChanged" IsSnapToTickEnabled="True" TickFrequency="1"/>
        <Slider x:Name="Slider_Startlenght" Canvas.Left="77" Canvas.Top="300" Width="154" HorizontalAlignment="Center" VerticalAlignment="Top" Minimum="1" Maximum="5" Value="1" ValueChanged="Slider_Startlenght_ValueChanged" IsSnapToTickEnabled="True" TickFrequency="1"/>
        <Slider x:Name="Slider_Startspeed" Canvas.Left="77" Canvas.Top="370" Width="154" HorizontalAlignment="Center" VerticalAlignment="Top" Minimum="1" Maximum="10" Value="1" ValueChanged="Slider_Startspeed_ValueChanged" IsSnapToTickEnabled="True" TickFrequency="1"/>
        <Label Foreground="#7AFE80" FontWeight="Bold" FontSize="20" Content="Feldweite" Canvas.Left="240" Canvas.Top="148" HorizontalAlignment="Center" VerticalAlignment="Top" Width="115"/>
        <Label Foreground="#7AFE80" FontWeight="Bold" FontSize="20" Content="Feldhöhe" Canvas.Left="240" Canvas.Top="218" Width="115" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Label Foreground="#7AFE80" FontWeight="Bold" FontSize="20" Content="Startlänge" Canvas.Left="240" Canvas.Top="288" Width="115" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Label VerticalContentAlignment="Center" Foreground="#7AFE80" FontWeight="Bold" FontSize="20" Content="Startspeed" Canvas.Left="240" Canvas.Top="358" Width="184" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Button Content="Speichern+Beenden" Canvas.Left="114" Canvas.Top="408" Width="192" Height="40" HorizontalAlignment="Center" VerticalAlignment="Top" BorderBrush="#302C3F" BorderThickness="3" Background="#FF2F263C" Foreground="#7AFE80" Name="Button_quit" PreviewMouseDown="Button_quit_PreviewMouseDown" FontSize="18">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#FF2F263C"/>
                    <Setter Property="Foreground" Value="#7AFE80"/>
                    <Setter Property="BorderBrush" Value="#302C3F"/>
                    <Setter Property="BorderThickness" Value="3"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">

                                    <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border"
                                Property="Background"
                                Value="#444050"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>
    </Canvas>
</Window>
